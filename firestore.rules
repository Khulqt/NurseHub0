rules_version = '2';

// =========================================================
// NurseHub — Firestore Security Rules
// Paste this into: Firebase Console → Firestore Database → Rules
//
// Model:
//  - Only the admin signs in (Firebase Authentication, email/password).
//  - request.auth != null  ==  "the admin is making this request".
//  - Everyone else (site visitors) is unauthenticated and can only do
//    the narrow set of actions the product needs (register, rate, read
//    approved profiles) — never read the sensitive nurses_private data.
// =========================================================

function isAdmin() {
  return request.auth != null;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------- nurses (public profile fields) ----------------
    match /nurses/{nurseId} {
      // Visitors may only read approved & non-blocked profiles.
      // The admin (authenticated) may read everything, incl. pending ones.
      allow read: if isAdmin() ||
        (resource.data.approved == true && resource.data.blocked == false);

      // Public registration: anyone may create a profile, but it must
      // start in the correct "pending" state — no one can self-approve,
      // self-verify, or fabricate stats.
      allow create: if
        request.resource.data.approved == false &&
        request.resource.data.verified == false &&
        request.resource.data.blocked == false &&
        request.resource.data.rating == 0 &&
        request.resource.data.ratingCount == 0 &&
        request.resource.data.visits == 0 &&
        request.resource.data.name is string &&
        request.resource.data.phone is string;

      // Only the admin can approve/edit/verify/block existing profiles.
      // Exception: the registration flow itself needs to attach the
      // photoURL right after upload, before admin review — allowed only
      // if no protected field is being changed.
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['photoURL']) &&
        resource.data.approved == false
      ) || (
        // allow the visit counter to increment for anyone viewing a profile
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visits'])
      );

      allow delete: if isAdmin();
    }

    // ---------------- nurses_private (national ID — admin only read) --
    match /nurses_private/{nurseId} {
      allow read: if isAdmin();
      // Created once during registration, right after the public doc.
      allow create: if request.resource.data.nationalId is string &&
                       request.resource.data.nationalId.size() == 14;
      allow update, delete: if isAdmin();
    }

    // ---------------- ratings (public reviews) ----------------
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if
        request.resource.data.nurseId is string &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.comment is string &&
        request.resource.data.comment.size() > 0 &&
        request.resource.data.stars is int &&
        request.resource.data.stars >= 1 &&
        request.resource.data.stars <= 5;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ---------------- ads ----------------
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------------- notifications ----------------
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
